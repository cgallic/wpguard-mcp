# Copy to .env and fill in. Never commit the real .env.

# --- Server auth (required) ---
# Bearer token every MCP client must send. The server fails closed if this
# is unset -- there is no unauthenticated mode. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
WPGUARD_MCP_TOKEN=

# --- Server networking (optional, defaults shown) ---
WPGUARD_MCP_HOST=127.0.0.1
WPGUARD_MCP_PORT=8642

# --- Local state directory (optional, defaults to ./state) ---
# Holds the packet ledger (state/packets/packets.jsonl), write snapshots
# (state/packets/snapshots.jsonl), and the site registry
# (state/config/sites.json). All gitignored.
WPGUARD_STATE_DIR=state

# --- Guard bypass (optional, dangerous) ---
# Set to 1 to let apply=True mutations run without an open change packet.
# Intended only for non-mutating diagnostic calls during development. Do not
# set this in any environment you'd call "production."
WPGUARD_BYPASS_GUARD=0

# --- Per-site credentials ---
# Sites are registered via the site_register tool, which stores connection
# metadata (hosts, paths, URLs) in state/config/sites.json -- but never
# secrets. Secrets live only in env vars, referenced by name from the site
# registry entry.
#
# SSH-transport sites authenticate via your normal SSH key/agent -- no env
# var needed unless your key is passphrase-protected and not in ssh-agent,
# in which case wpguard-mcp expects ssh-agent to already have it loaded.
#
# companion_plugin-transport sites need one API key env var per site. Name
# it whatever you like and point site_register's plugin_api_key_env at it,
# e.g. for a site registered as "example-blog":
WPGUARD_SITE_EXAMPLE_BLOG_KEY=
